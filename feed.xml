---
layout: null
permalink: /feed.xml
sitemap: false
---
{% assign feed_title = site.data.site.title | default: site.title %}
{% assign feed_description = site.data.site.description | default: site.description %}
{% assign author_name = site.data.profile.display_name | default: site.data.profile.name | default: feed_title %}
{% assign feed_updated = site.time %}
{% assign feed_post_count = 0 %}
{% for post in site.posts %}
  {% unless post.published == false or post.noindex == true %}
    {% if feed_post_count == 0 %}{% assign feed_updated = post.last_modified_at | default: post.date %}{% endif %}
    {% assign feed_post_count = feed_post_count | plus: 1 %}
  {% endunless %}
{% endfor %}
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="{{ site.data.site.language | default: site.lang | default: 'ko' | xml_escape }}">
  <title>{{ feed_title | xml_escape }}</title>
  <subtitle>{{ feed_description | xml_escape }}</subtitle>
  <id>{{ '/' | absolute_url | xml_escape }}</id>
  <link href="{{ '/' | absolute_url | xml_escape }}" rel="alternate" />
  <link href="{{ '/feed.xml' | absolute_url | xml_escape }}" rel="self" type="application/atom+xml" />
  <updated>{{ feed_updated | date_to_xmlschema }}</updated>
  <author><name>{{ author_name | xml_escape }}</name></author>
  {% assign emitted_feed_entries = 0 %}
  {% for post in site.posts %}
    {% unless post.published == false or post.noindex == true %}
      {% if emitted_feed_entries < 20 %}
        {% assign entry_description = post.description | default: post.excerpt | strip_html | strip_newlines | normalize_whitespace | truncate: 500 %}
        <entry>
          <title>{{ post.title | xml_escape }}</title>
          <id>{{ post.url | absolute_url | xml_escape }}</id>
          <link href="{{ post.url | absolute_url | xml_escape }}" rel="alternate" />
          <published>{{ post.date | date_to_xmlschema }}</published>
          <updated>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</updated>
          <author><name>{{ author_name | xml_escape }}</name></author>
          <summary type="text">{{ entry_description | xml_escape }}</summary>
          {% for category in post.categories %}<category term="{{ category | xml_escape }}" />{% endfor %}
          {% for tag in post.tags %}<category term="{{ tag | xml_escape }}" />{% endfor %}
          {% if post.series and post.series != '' %}<category term="{{ post.series | xml_escape }}" scheme="series" />{% endif %}
        </entry>
        {% assign emitted_feed_entries = emitted_feed_entries | plus: 1 %}
      {% endif %}
    {% endunless %}
  {% endfor %}
</feed>
